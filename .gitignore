# â”€â”€ Srodowiska wirtualne â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
.venv/
venv/
env/
ENV/
.python-version

# â”€â”€ Zmienne srodowiskowe - NIGDY nie commituj .env â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
.env
backend/.env
worker/.env
!.env.example

# â”€â”€ Logi aplikacji - zawartosc ignorowana, katalog sledzony â”€
logs/*.log
logs/*.jsonl
logs/*.json
backend/logs/*.log
backend/logs/*.jsonl
backend/logs/*.json
worker/logs/*.log
worker/logs/*.jsonl
worker/logs/*.json
# Zachowaj katalogi w repo
!logs/.gitkeep
!backend/logs/.gitkeep

# â”€â”€ Snapshoty i archiwa - tylko pliki ignorowane â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
snapshots/**/*.json.gz
snapshots/**/*.json
archives/**/*.json.gz
archives/**/*.json
!snapshots/.gitkeep
!archives/.gitkeep

