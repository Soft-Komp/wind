#########################################
# COOKIE — HttpOnly refresh token
# Konfiguracja zgodna z wymaganiami frontendu (v2.0)
#########################################

# Nazwa cookie (zmiana invaliduje wszystkie sesje!)
COOKIE_NAME=refresh_token

# false TYLKO na localhost/dev (brak HTTPS na http://localhost)
# Na produkcji OBOWIĄZKOWO: COOKIE_SECURE=true
COOKIE_SECURE=false

# strict — rekomendacja frontendu, max ochrona CSRF
# Działa poprawnie dla SPA (app.pl) + API (api.app.pl) — same-site
COOKIE_SAMESITE=strict

# Path ogranicza scope cookie wyłącznie do endpointów auth
COOKIE_PATH=/api/v1/auth

# Domain: puste na dev, na produkcji ustaw np.: COOKIE_DOMAIN=api.app.pl
COOKIE_DOMAIN=
